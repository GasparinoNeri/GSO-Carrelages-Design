.profile-page {
  min-height: 100vh;
  padding: 40px;

  display: flex;
  justify-content: center;
  align-items: center;

  background:
    linear-gradient(rgba(255,255,255,0.82), rgba(255,255,255,0.82)),
    url('/assets/gso-logo-bg.png');

  background-size: cover;
  background-position: center;
  background-attachment: fixed;
}

.profile-card {
  background: white;
  width: 450px;
  padding: 35px;
  border-radius: 18px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.25);
}

.profile-card h1 {
  color: #1e3a5f;
  text-align: center;
  margin-bottom: 25px;
}

.profile-info p {
  font-size: 1.1rem;
  margin: 14px 0;
}